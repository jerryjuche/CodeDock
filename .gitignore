# =============================================================================
# CodeDock — Root .gitignore
# Covers: Go backend · Next.js frontend · VS Code extension · Docker · Scripts
# =============================================================================


# =============================================================================
# SECRETS & ENVIRONMENT
# =============================================================================
.env
.env.*
!.env.example
!codedock-web/.env.example

# Per-workspace local env overrides
*.env.local
.env.local
.env.*.local
codedock-web/.env.local
codedock-web/.env.*.local


# =============================================================================
# GO
# =============================================================================

# Compiled binaries & test binaries
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test

# Go build output (root-level server binary)
codedock-server
codedock_test_bin

# Test & coverage artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Go workspace (not used; lock out accidentally)
go.work
go.work.sum

# Vendor directory (uncomment if you vendor deps)
# vendor/


# =============================================================================
# NODE / JAVASCRIPT / TYPESCRIPT
# =============================================================================

# All node_modules across the monorepo
node_modules/
**/node_modules/

# npm / yarn debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Build & cache output
dist/
**/dist/
build/
**/build/
coverage/
**/coverage/
.cache/
**/.cache/


# =============================================================================
# NEXT.JS (codedock-web)
# =============================================================================
codedock-web/.next/
codedock-web/out/
codedock-web/.vercel/
codedock-web/tsconfig.tsbuildinfo


# =============================================================================
# VS CODE EXTENSION (extension/)
# =============================================================================

# Compiled output
extension/out/
extension/dist/

# Packaged extension artifacts
extension/*.vsix

# Extension TypeScript build info
extension/tsconfig.tsbuildinfo


# =============================================================================
# VERCEL
# =============================================================================
.vercel/
.vercel


# =============================================================================
# DOCKER
# =============================================================================
# (No Docker build artifacts tracked — Docker uses .dockerignore to exclude
#  what enters the build context; nothing Docker-specific lives in the source tree)


# =============================================================================
# DEBUG / LOCAL EXPORTS
# =============================================================================
debug-dumps/
tmp/
temp/
*.tmp


# =============================================================================
# BACKUP FILES (generated by in-place edit scripts)
# =============================================================================
*.bak
*.bak.*


# =============================================================================
# DATABASE
# =============================================================================
# Local PostgreSQL data directories (if running db locally via Docker volume)
pgdata/
postgres-data/


# =============================================================================
# OS & EDITOR ARTIFACTS
# =============================================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# VS Code workspace settings (keep .vscode/launch.json but ignore personal settings)
.vscode/settings.json
.vscode/*.code-workspace

# JetBrains IDEs
.idea/
*.iml

# Vim / Neovim
*.swp
*.swo
Session.vim


# =============================================================================
# LOGS
# =============================================================================
*.log
logs/


# =============================================================================
# TEST DASHBOARD (internal tooling — not a production artifact)
# =============================================================================
codedock-test-dashboard/frontend/node_modules/
codedock-test-dashboard/frontend/.next/
codedock-test-dashboard/frontend/dist/
codedock-test-dashboard/frontend/build/
# Dependencies
node_modules/
**/node_modules/

# Frontend build/cache
.next/
**/.next/
dist/
**/dist/
build/
**/build/
coverage/
**/coverage/
*.tsbuildinfo

# VS Code extension build/package output
extension/out/
extension/dist/
extension/*.vsix
*.vsix

# Local deployment/config
.env
.env.*
!.env.example
.vercel/
debug-dumps/

# Go build artifacts
codedock_test_bin
codedock-server
*.test
*.out
*.coverprofile

# Dependencies
node_modules/
**/node_modules/

# Frontend build/cache
.next/
**/.next/
dist/
**/dist/
build/
**/build/
coverage/
**/coverage/
*.tsbuildinfo

# VS Code extension build/package output
extension/out/
extension/dist/
extension/*.vsix
*.vsix

# Local deployment/config
.env
.env.*
!.env.example
.vercel/
debug-dumps/

# Go build artifacts
codedock_test_bin
codedock-server
*.test
*.out
*.coverprofile
