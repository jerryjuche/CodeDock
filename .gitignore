# =============================================================================
# CodeDock — .gitignore
# Covers: Go backend · Next.js frontend · VS Code extension · Docker · Scripts
# =============================================================================


# ── Secrets & Environment ────────────────────────────────────────────────────
.env
.env.*
*.env.local
.env.local
.env.*.local
codedock-web/.env.local
codedock-web/.env.*.local
!.env.example
!codedock-web/.env.example


# ── Go ───────────────────────────────────────────────────────────────────────
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
*.coverprofile
profile.cov
coverage.*
codedock-server
codedock_test_bin
go.work
go.work.sum
# vendor/


# ── Node / JavaScript / TypeScript ──────────────────────────────────────────
node_modules/
**/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*


# ── Build & Cache Output ────────────────────────────────────────────────────
dist/
**/dist/
build/
**/build/
coverage/
**/coverage/
.cache/
**/.cache/
*.tsbuildinfo


# ── Next.js (codedock-web) ──────────────────────────────────────────────────
.next/
**/.next/
out/


# ── VS Code Extension (extension/) ─────────────────────────────────────────
extension/out/
extension/dist/
extension/*.vsix
*.vsix


# ── Vercel ──────────────────────────────────────────────────────────────────
.vercel/
.vercel


# ── Docker ──────────────────────────────────────────────────────────────────
*.dockerignore.bak


# ── Debug & Temp Files ──────────────────────────────────────────────────────
debug-dumps/
**/debug-dumps/
tmp/
temp/
*.tmp
*.temp
*.bak
*.bak.*
*.orig
*.rej
*~


# ── OS Artifacts ────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.AppleDouble
.LSOverride
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/


# ── IDE & Editor ────────────────────────────────────────────────────────────
.vscode/
.idea/
*.iml
*.sublime-project
*.sublime-workspace
*.swp
*.swo
Session.vim


# ── Logs ────────────────────────────────────────────────────────────────────
*.log
logs/


# ── Database ────────────────────────────────────────────────────────────────
pgdata/
postgres-data/


# ── AI / Generated Artifacts (not project docs) ────────────────────────────
/implementation_plan.md
/walkthrough.md