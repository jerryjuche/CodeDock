# =============================================================================
# CodeDock — Root .gitignore
# Covers: Go backend · Next.js frontend · VS Code extension · Docker · Scripts
# =============================================================================

# -----------------------------------------------------------------------------
# Secrets & Environment Variables
# -----------------------------------------------------------------------------
.env
.env.*
.env.local
.env.*.local
*.env
*.env.local
!.env.example
!codedock-web/.env.example

# -----------------------------------------------------------------------------
# Dependencies (Monorepo Node Modules)
# -----------------------------------------------------------------------------
node_modules/
**/node_modules/

# -----------------------------------------------------------------------------
# Compiled Binaries & Build Outputs
# -----------------------------------------------------------------------------
# Go Binaries (Root level & workspace)
CodeDock
codedock-server
codedock_backend
codedock_test_bin
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
*.coverprofile
profile.cov

# Next.js Build Outputs (codedock-web & test dashboard)
.next/
**/.next/
out/
**/out/
build/
**/build/
dist/
**/dist/
.vercel/
**/.vercel/
*.tsbuildinfo

# VS Code Extension Packaging
extension/out/
extension/dist/
extension/*.vsix
*.vsix

# -----------------------------------------------------------------------------
# Development & Debug Logs
# -----------------------------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
logs/
debug-dumps/
**/debug-dumps/

# -----------------------------------------------------------------------------
# System & Editor Files
# -----------------------------------------------------------------------------
# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Vim / Neovim
*.swp
*.swo
*~
Session.vim

# JetBrains
.idea/
*.iml

# VS Code
.vscode/settings.json
.vscode/*.code-workspace

# -----------------------------------------------------------------------------
# Temporary & One-off Scripts
# -----------------------------------------------------------------------------
tmp/
temp/
*.tmp
*.temp
*.bak
*.orig
*.rej
do.txt
tmp_rewrite_review_page.py

# -----------------------------------------------------------------------------
# AI Tools
# -----------------------------------------------------------------------------
.continue/
