{
  "name": "codedock",
  "displayName": "CodeDock",
  "description": "Self-hosted real-time collaborative coding for VS Code",
  "version": "0.1.0",
  "publisher": "jerryjuche",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codedock.login",
        "title": "CodeDock: Login"
      },
      {
        "command": "codedock.logout",
        "title": "CodeDock: Logout"
      },
      {
        "command": "codedock.joinRoom",
        "title": "CodeDock: Join Room"
      },
      {
        "command": "codedock.createRoom",
        "title": "CodeDock: Create Room"
      },
      {
        "command": "codedock.openChat",
        "title": "CodeDock: Open Chat"
      },
      {
        "command": "codedock.disconnectRoom",
        "title": "CodeDock: Disconnect from Room"
      }
    ],
    "configuration": {
      "title": "CodeDock",
      "properties": {
        "codedock.serverUrl": {
          "type": "string",
          "default": "https://codedock.fly.dev",
          "description": "Base URL of the CodeDock backend server"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc --noEmit && node esbuild.js",
    "watch": "tsc -watch -p ./",
    "build": "node esbuild.js",
    "lint": "eslint src --ext ts"
  },
  "dependencies": {
    "yjs": "^13.6.30"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.9.3"
  }
}
