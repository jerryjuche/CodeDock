+		UPDATE rooms
+		SET is_active = FALSE,
+		    updated_at = NOW()
+		WHERE id = $1
+		  AND owner_user_id = $2
+		  AND is_active = TRUE
+	`, roomID, userID)
+	if err != nil {
+		return err
+	}
+
+	rowsAffected, err := result.RowsAffected()
+	if err != nil {
+		return err
+	}
+	if rowsAffected == 0 {
+		return ErrRoomNotFound
+	}
+
+	_, _ = s.DB.Exec(`
+		UPDATE room_launch_tokens
+		SET used_at = COALESCE(used_at, NOW())
+		WHERE room_id = $1
+		  AND used_at IS NULL
+	`, roomID)
+
+	return nil
+}
