# =============================================================================
# CodeDock — .vercelignore
# Place this file at: codedock-web/.vercelignore
# Scope: Tells Vercel what NOT to upload when deploying the Next.js frontend.
#        The Vercel root is configured to codedock-web/ in the project settings.
# =============================================================================


# =============================================================================
# SECRETS (never upload)
# =============================================================================
.env
.env.*
!.env.example


# =============================================================================
# NEXT.JS BUILD CACHE (Vercel rebuilds from source)
# =============================================================================
.next/
out/


# =============================================================================
# DEPENDENCIES (Vercel installs fresh)
# =============================================================================
node_modules/


# =============================================================================
# TYPESCRIPT BUILD INFO
# =============================================================================
tsconfig.tsbuildinfo
next-env.d.ts


# =============================================================================
# TEST & COVERAGE
# =============================================================================
coverage/
*.coverprofile
*.out


# =============================================================================
# EDITOR & OS ARTIFACTS
# =============================================================================
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo


# =============================================================================
# BACKUP FILES
# =============================================================================
*.bak
*.bak.*


# =============================================================================
# LOCAL DEBUG
# =============================================================================
debug-dumps/
tmp/